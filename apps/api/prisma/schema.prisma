generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VoteType {
  AGREE
  DISAGREE
  PARTIALLY
  RELEVANT
  IRRELEVANT
  NEW_TO_ME
}

enum SpaceStatus {
  ACTIVE
  MATURE
  ARCHIVED
}

enum StatementIntent {
  EXPAND_AGREEMENT
  EXPLORE_DISAGREEMENT
}

model User {
  id                 String              @id @default(uuid())
  username           String              @unique
  email              String              @unique
  passwordHash       String
  createdAt          DateTime            @default(now())
  posts              Post[]
  votes              Vote[]
  clusterMemberships ClusterMembership[]
  statements         ConsensusStatement[]
  statementVotes     StatementVote[]
  notifications      Notification[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Post {
  id        String   @id @default(uuid())
  content   String   @db.VarChar(280)
  authorId  String
  topicId   String?
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topic     Topic?   @relation(fields: [topicId], references: [id])
  votes     Vote[]
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  type      VoteType
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Cluster {
  id               String            @id @default(uuid())
  vectorSignature  Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          ClusterMembership[]
  consensusSpacesA ConsensusSpace[]  @relation("ClusterA")
  consensusSpacesB ConsensusSpace[]  @relation("ClusterB")
}

model ClusterMembership {
  userId    String
  clusterId String
  weight    Float
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cluster   Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@id([userId, clusterId])
}

model ConsensusSpace {
  id           String               @id @default(uuid())
  clusterAId   String
  clusterBId   String
  anchorPostId String
  status       SpaceStatus          @default(ACTIVE)
  createdAt    DateTime             @default(now())
  clusterA     Cluster              @relation("ClusterA", fields: [clusterAId], references: [id], onDelete: Cascade)
  clusterB     Cluster              @relation("ClusterB", fields: [clusterBId], references: [id], onDelete: Cascade)
  statements   ConsensusStatement[]
  document     ConsensusDocument?
}

model ConsensusStatement {
  id        String          @id @default(uuid())
  content   String          @db.VarChar(280)
  intent    StatementIntent
  spaceId   String
  authorId  String
  space     ConsensusSpace  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes     StatementVote[]
}

model StatementVote {
  id          String             @id @default(uuid())
  userId      String
  statementId String
  type        VoteType
  createdAt   DateTime           @default(now())
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement   ConsensusStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@unique([userId, statementId])
}

model ConsensusDocument {
  id        String         @id @default(uuid())
  spaceId   String         @unique
  content   Json
  createdAt DateTime       @default(now())
  space     ConsensusSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Topic {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[]
}
