# Copia este archivo a .env en esta misma carpeta (apps/api/.env).
# La API carga siempre apps/api/.env aunque ejecutes pnpm desde la raíz del monorepo.

# PostgreSQL (p. ej. docker compose en la raíz del repo)
DATABASE_URL=postgresql://meliora:meliora@localhost:5432/meliora

# Obligatorio: firma JWT (mín. 8 caracteres; en producción usa un secreto largo y aleatorio)
JWT_SECRET=change-me-in-development

# Origen del front (CORS + Socket.IO)
CORS_ORIGIN=http://localhost:3000

# Puerto HTTP de la API
PORT=4000

NODE_ENV=development

# Microservicio ML (clustering / consenso); opcional si no lo usas aún
ML_SERVICE_URL=http://localhost:8000

# Reservado para uso futuro (caché / colas)
# REDIS_URL=redis://localhost:6379
