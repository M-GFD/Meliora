{
  "name": "meliora",
  "version": "0.1.0",
  "private": true,
  "description": "Meliora — infraestructura de deliberación cívica e inteligencia colectiva",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"pnpm --filter @meliora/web dev\" \"pnpm --filter @meliora/api dev\"",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "db:generate": "pnpm --filter @meliora/api exec prisma generate",
    "db:migrate": "pnpm --filter @meliora/api exec prisma migrate dev",
    "db:push": "pnpm --filter @meliora/api exec prisma db push"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
